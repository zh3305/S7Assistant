<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:S7Assistant.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="S7Assistant.Views.ConfigurationManagerWindow"
        x:DataType="vm:ConfigurationManagerViewModel"
        Title="配置管理器"
        Width="1100" Height="700"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:ConfigurationManagerViewModel/>
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="10">
            <Grid ColumnDefinitions="*,Auto">
                <!-- 配置管理区域 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <TextBlock VerticalAlignment="Center" Text="配置文件:"/>
                    <ComboBox Width="150"
                              ItemsSource="{Binding ConfigFiles}"
                              SelectedItem="{Binding SelectedConfigFile}"
                              MinWidth="100"/>
                    <Button Content="加载" Command="{Binding LoadSelectedConfigCommand}" Padding="8,4"/>
                    <Button Content="删除" Command="{Binding DeleteSelectedConfigCommand}" Padding="8,4"/>

                    <TextBlock VerticalAlignment="Center" Text="新配置:" Margin="20,0,0,0"/>
                    <TextBox Width="120" Text="{Binding NewConfigName}"/>
                    <Button Content="创建" Command="{Binding CreateNewConfigCommand}" Padding="8,4"/>
                </StackPanel>

                <!-- 保存按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                    <Button Content="保存配置"
                            Command="{Binding SaveConfigCommand}"
                            Background="Green"
                            Foreground="White"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 内容区域 - 三栏布局 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧 - Package 列表 -->
            <Grid Grid.Column="0" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Package 工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" Spacing="10">
                    <TextBlock Text="数据包列表" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="添加" Command="{Binding AddPackageCommand}" Padding="8,4" FontSize="11"/>
                    <Button Content="删除" Command="{Binding DeleteSelectedPackageCommand}" Padding="8,4" FontSize="11"/>
                </StackPanel>

                <!-- Package 列表 -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding CurrentPackages}"
                          SelectedItem="{Binding SelectedPackage}"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="All"
                          BorderThickness="1"
                          BorderBrush="Gray"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="区域" Binding="{Binding Area}" Width="50"/>
                        <DataGridTextColumn Header="起始" Binding="{Binding StartAddress}" Width="50"/>
                        <DataGridTextColumn Header="长度" Binding="{Binding Length}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Package 编辑区 -->
                <Border Grid.Row="2" Background="#f5f5f5" Padding="10" Margin="0,10,0,0" CornerRadius="4"
                        IsVisible="{Binding IsPackageSelected}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="编辑数据包" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditPackageName}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="区域:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      SelectedItem="{Binding EditArea}"
                                      ItemsSource="{Binding AreaTypes}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="DB号:" VerticalAlignment="Center"
                                       IsVisible="{Binding IsPackageSelected}"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                          Value="{Binding EditDbNumber}"
                                          Minimum="1" Maximum="65535"
                                          IsVisible="{Binding IsPackageSelected}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="起始:" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="3" Grid.Column="1"
                                          Value="{Binding EditStartAddress}"
                                          Minimum="0" Maximum="65535"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="长度:" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="4" Grid.Column="1"
                                          Value="{Binding EditLength}"
                                          Minimum="1" Maximum="65535"/>
                        </Grid>
                        <Button Content="应用修改" Command="{Binding ApplyPackageEditCommand}"
                                HorizontalAlignment="Stretch" Padding="8,4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 中间 - 数据项列表 -->
            <Grid Grid.Column="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 数据项工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" Spacing="10">
                    <TextBlock Text="数据项列表" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="添加" Command="{Binding AddDataItemCommand}" Padding="8,4" FontSize="11"
                            IsEnabled="{Binding IsPackageSelected}"/>
                    <Button Content="删除" Command="{Binding DeleteSelectedDataItemCommand}" Padding="8,4" FontSize="11"
                            IsEnabled="{Binding IsItemSelected}"/>
                </StackPanel>

                <!-- 数据项列表 -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SelectedPackage.Items}"
                          SelectedItem="{Binding SelectedDataItem}"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="All"
                          BorderThickness="1"
                          BorderBrush="Gray"
                          IsReadOnly="True"
                          IsEnabled="{Binding IsPackageSelected}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="60"/>
                        <DataGridTextColumn Header="偏移" Binding="{Binding Offset}" Width="50"/>
                        <DataGridTextColumn Header="位" Binding="{Binding BitOffset}" Width="40"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 数据项编辑区 -->
                <Border Grid.Row="2" Background="#f5f5f5" Padding="10" Margin="0,10,0,0" CornerRadius="4"
                        IsVisible="{Binding IsItemSelected}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="编辑数据项" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="60,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditItemName}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="类型:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="1" Grid.Column="1"
                                      SelectedItem="{Binding EditItemType}"
                                      ItemsSource="{Binding DataTypes}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="偏移:" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1"
                                          Value="{Binding EditItemOffset}"
                                          Minimum="0" Maximum="65535"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="位号:" VerticalAlignment="Center"
                                       IsVisible="{Binding ShowBitOffsetEditor}"/>
                            <NumericUpDown Grid.Row="3" Grid.Column="1"
                                          Value="{Binding EditItemBitOffset}"
                                          Minimum="0" Maximum="7"
                                          IsVisible="{Binding ShowBitOffsetEditor}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="备注:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditItemRemark}"/>
                        </Grid>
                        <Button Content="应用修改" Command="{Binding ApplyDataItemEditCommand}"
                                HorizontalAlignment="Stretch" Padding="8,4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 右侧 - 预览和说明 -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1,0,0,0" Padding="15">
                <ScrollViewer>
                    <StackPanel Spacing="12">
                        <TextBlock Text="配置说明" FontWeight="Bold" FontSize="16"/>

                        <TextBlock Text="数据包 (Package)" FontWeight="SemiBold" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="每个数据包对应一次 PLC 批量读取操作。包内的数据项共享同一缓冲区，通过偏移量解析各字段。"
                                   TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="建议：将相同读取频率、相邻地址的数据项组织到同一个包中。"
                                   TextWrapping="Wrap" Foreground="#555"/>

                        <TextBlock Text="数据项 (Item)" FontWeight="SemiBold" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="偏移量 (Offset): 相对于数据包起始地址的字节偏移" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="位号 (BitOffset): 仅 Bit 类型需要，0-7" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="类型 (Type): 数据类型决定读取长度" TextWrapping="Wrap" Foreground="#555"/>

                        <TextBlock Text="区域类型" FontWeight="SemiBold" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="DB - 数据块 (需设置 DB号)" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="I - 输入区" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="Q - 输出区" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="M - 位存储器" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="T - 定时器" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="C - 计数器" TextWrapping="Wrap" Foreground="#555"/>

                        <TextBlock Text="操作流程" FontWeight="SemiBold" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="1. 选择或创建配置文件" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="2. 添加/编辑数据包" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="3. 在包内添加数据项" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="4. 保存配置" TextWrapping="Wrap" Foreground="#555"/>
                        <TextBlock Text="5. 应用并关闭" TextWrapping="Wrap" Foreground="#555"/>

                        <TextBlock Text="提示: 修改后请点击保存按钮保存更改"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"
                                   Foreground="Red"
                                   FontSize="11"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#f0f0f0" Padding="10,5">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="应用并关闭"
                        Command="{Binding ApplyAndCloseCommand}"
                        Background="#2196F3"
                        Foreground="White"
                        Padding="15,8"/>
            </Grid>
        </Border>
    </Grid>
</Window>
